# Server Configuration
PORT=3001
NODE_ENV=development

# Redis Configuration (for background export queue)
REDIS_HOST=localhost
REDIS_PORT=6379

# Translation API (Groq - Fast LLM)
# Get API key from https://console.groq.com/
GROQ_API_KEY=

# File Upload Settings
MAX_FILE_SIZE=500MB
UPLOAD_DIR=./backend/uploads

# FFmpeg Settings (ensure FFmpeg is installed on the system)
# FFmpeg should be available in PATH